# UTP Platform Environment Variables
# Copy this file to .env and fill in values

# ---- Blockchain ----
RSK_TESTNET_RPC_URL=https://public-node.testnet.rsk.co
RSK_MAINNET_RPC_URL=https://public-node.rsk.co
DEPLOYER_PRIVATE_KEY=
REPORT_GAS=false

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_WC_PROJECT_ID=
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ---- News API ----
NEWSDATA_API_KEY=
# Get free key: https://newsdata.io/register

# ---- Legislature API ----
CONGRESS_API_KEY=
# Get free key: https://api.congress.gov/sign-up

# ---- Security ----
IP_SALT=change_me_to_random_string

# ---- News Aggregation (optional) ----
MEDIASTACK_API_KEY=
# Get free key: https://mediastack.com/signup/free
WORLD_NEWS_API_KEY=
# Get free key: https://worldnewsapi.com/
